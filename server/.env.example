# ============================================================
# Backend configuration — copy to `.env` and fill in.
# .env is gitignored. NEVER commit real credentials.
# ============================================================

# --- Server ---
PORT=8787
# Comma-separated origins allowed to call the API (the Vite app).
CORS_ORIGIN=http://localhost:5173

# --- PostgreSQL (your pgAdmin server) ---
# Format: postgres://USER:PASSWORD@HOST:5432/DBNAME
# Host is your server (13.202.225.50). Keep the real password ONLY here.
DATABASE_URL=postgres://postgres:CHANGE_ME@13.202.225.50:5432/vsl_funnel
# Set to "true" if the server requires SSL (recommended for a public host).
DATABASE_SSL=false

# --- Booking / slots ---
# Minutes a selected slot is held pending payment before auto-release.
HOLD_WINDOW_MINUTES=12

# --- Payments (Razorpay) ---
# RAZORPAY_MODE=mock lets the whole funnel be tested with NO real keys
# (orders are faked and verification auto-succeeds). Switch to "live" once
# you add the keys below.
RAZORPAY_MODE=mock
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
# From the Razorpay dashboard when you create the webhook (Settings → Webhooks).
RAZORPAY_WEBHOOK_SECRET=
PRICE_PAISE=9900

# --- WhatsApp (Whapi.cloud) ---
# If WHAPI_TOKEN is empty, messages are skipped and the lead is flagged
# `needs_wa` in the DB (visible in the admin panel) instead.
WHAPI_TOKEN=
WHAPI_BASE_URL=https://gate.whapi.cloud

# --- Admin panel ---
# Simple shared bearer token the admin UI sends with each request.
ADMIN_TOKEN=change-me-admin-token
